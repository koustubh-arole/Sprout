# ---- Sprout environment ----
# The AI coach runs ENTIRELY server-side (see app/api/coach/route.ts), so these
# keys never reach the browser bundle. Without a key the app automatically falls
# back to deterministic, hard-coded coaching — the deployed link still works.
#
# Copy this file to `.env.local` and fill in a key to enable the live AI coach.

# Which provider to use: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq API key (only needed if LLM_PROVIDER=groq) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
